{
  "name": "scrumpkr.net",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "preview": "react-router build && vite preview",
    "deploy": "react-router build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "test": "vitest run && vitest run --config vitest.workers.config.ts",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "typecheck": "wrangler types && react-router typegen && tsc -b",
    "postinstall": "wrangler types"
  },
  "dependencies": {
    "isbot": "^5.1.39",
    "lucide-react": "^0.511.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "7.14.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.1",
    "@cloudflare/vitest-pool-workers": "^0.14.9",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}