{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "scrumpkr",
  "compatibility_date": "2025-04-04",
  "main": "./workers/app.ts",
  "durable_objects": {
    "bindings": [
      {
        "name": "POKER_ROOM",
        "class_name": "PokerRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["PokerRoom"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
